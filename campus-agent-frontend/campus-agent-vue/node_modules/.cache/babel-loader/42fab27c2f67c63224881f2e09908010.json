g-primary text-white\">\r\n            今日课表（{{ getWeekday() }}）\r\n          </div>\r\n          <div class=\"card-body\">\r\n            <table class=\"table table-sm table-hover\">\r\n              <thead>\r\n                <tr>\r\n                  <th>课程名称</th>\r\n                  <th>上课时间</th>\r\n                  <th>上课地点</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                <tr v-for=\"(item, index) in scheduleList\" :key=\"index\">\r\n                  <td>{{ item.courseName }}</td>\r\n                  <td>{{ item.time }}</td>\r\n                  <td>{{ item.place }}</td>\r\n                </tr>\r\n                <tr v-if=\"scheduleList.length === 0\">\r\n                  <td colspan=\"3\" class=\"text-center text-muted\">今日无课，好好休息～</td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Navbar from '../components/Navbar.vue'\r\nexport default {\r\n  name: 'Schedule',\r\n  components: { Navbar },\r\n  data() {\r\n    return {\r\n      scheduleList: [], // 课表列表\r\n      userId: this.$cookies.get('userId') || 1 // 从Cookies获取用户ID\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getTodaySchedule()\r\n  },\r\n  methods: {\r\n    // 获取今日课表\r\n    async getTodaySchedule() {\r\n      try {\r\n        const res = await this.$axios.get('/schedule/today', {\r\n          params: { userId: this.userId }\r\n        })\r\n        if (res.data.code === 200) {\r\n          this.scheduleList = res.data.data\r\n        }\r\n      } catch (err) {\r\n        console.error(err)\r\n        this.$message && this.$message.error('查询课表失败！')\r\n      }\r\n    },\r\n    // 获取当前星期几\r\n    getWeekday() {\r\n      const weekday = ['周日', '周一', '周二', '周三', '周四', '周五', '周六']\r\n      return weekday[new Date().getDay()]\r\n    }\r\n  }\r\n}\r\n</script>\r\n"],"mappings":"AAuCA,OAAAA,MAAA;AACA;EACAC,IAA