{"remainingRequest":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\babel-loader\\lib\\index.js!D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\src\\components\\ChatBox.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\src\\components\\ChatBox.vue","mtime":1776350813148},{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\babel.config.js","mtime":1775745205000},{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1776310730158},{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\babel-loader\\lib\\index.js","mtime":1776310731472},{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1776310730158},{"path":"D:\\11111\\code-agent-main\\campus-agent-frontend\\campus-agent-vue\\node_modules\\vue-loader\\lib\\index.js","mtime":1776310732052}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["ResultCard","name","components","data","inputContent","msgList","userId","selectedImages","selectedDocs","previewSrc","isRecording","mediaRecorder","audioChunks","computed","totalSelectedCount","length","mounted","$cookies","set","methods","triggerUpload","$refs","uploadInput","click","handleFileUpload","event","files","target","imageCount","docCount","i","file","type","startsWith","convertFileToBase64","base64","push","$message","warning","size","value","removeImage","index","splice","removeDoc","callback","reader","FileReader","onload","e","result","readAsDataURL","toggleVoice","stop","onstop","audioBlob","Blob","alert","stream","navigator","mediaDevices","getUserMedia","audio","MediaRecorder","ondataavailable","start","err","console","error","clearHistory","confirm","$axios","post","params","then","success","catch","previewImage","src","renderMarkdown","text","html","replace","hasMd","test","sendMsg","trim","hasImages","hasDocs","isUser","content","images","docs","$nextTick","chatContent","document","getElementById","scrollTop","scrollHeight","res","formData","FormData","append","headers","code","reply","intent","msg"],"sources":["src/components/ChatBox.vue"],"sourcesContent":["<template>\r\n  <div class=\"chat-box border rounded-3 p-3 h-100 d-flex flex-column\" style=\"height: 600px !important;\">\r\n    <!-- 对话内容区域 -->\r\n    <div class=\"chat-content flex-grow-1 overflow-auto mb-3\" id=\"chatContent\">\r\n      <!-- 机器人欢迎语 -->\r\n      <div class=\"d-flex mb-3 justify-content-start\">\r\n        <div class=\"bg-light rounded-3 p-3 shadow-sm max-w-75\">\r\n          你好～我是校园生活小管家，有什么可以帮你的？<br>\r\n          试试问我：<span class=\"text-primary\">今日课表</span>、<span class=\"text-primary\">食堂吃什么</span>、<span class=\"text-primary\">报修电话是多少</span>、<span class=\"text-primary\">下课后提醒我取快递</span>\r\n        </div>\r\n      </div>\r\n    <!-- 对话消息列表 -->\r\n    <div v-for=\"(msg, index) in msgList\" :key=\"index\" class=\"d-flex mb-3\" :class=\"msg.isUser ? 'justify-content-end' : 'justify-content-start'\">\r\n      <div :class=\"msg.isUser ? 'bg-primary text-white rounded-3 p-3 shadow-sm max-w-75' : 'bg-light rounded-3 p-3 shadow-sm max-w-75'\">\r\n        <!-- 用户消息：文本+图片预览+文档；AI消息：支持markdown渲染 -->\r\n        <template v-if=\"msg.isUser\">\r\n          <!-- 图片预览（多图） -->\r\n          <div v-if=\"msg.images && msg.images.length > 0\" class=\"mb-2 d-flex flex-wrap gap-2\">\r\n            <img v-for=\"(img, idx) in msg.images\" :key=\"idx\" :src=\"img\" class=\"rounded img-thumbnail\" style=\"max-width: 150px; max-height: 150px; cursor: pointer;\" @click=\"previewImage(img)\" />\r\n          </div>\r\n          <!-- 文档预览 -->\r\n          <div v-if=\"msg.docs && msg.docs.length > 0\" class=\"mb-2\">\r\n            <div v-for=\"(doc, idx) in msg.docs\" :key=\"idx\" class=\"d-flex align-items-center gap-2 bg-white bg-opacity-25 rounded px-2 py-1 mb-1\">\r\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" fill=\"currentColor\" viewBox=\"0 0 16 16\">\r\n                <path d=\"M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z\"/>\r\n              </svg>\r\n              <span style=\"font-size: 12px;\">{{ doc.name }}</span>\r\n            </div>\r\n          </div>\r\n          <div>{{ msg.content }}</div>\r\n        </template>\r\n        <div v-else class=\"ai-msg-content\" v-html=\"renderMarkdown(msg.content)\"></div>\r\n        <!-- 结果卡片：课表/提醒/知识库 -->\r\n        <ResultCard v-if=\"msg.data\" :data=\"msg.data\" :intent=\"msg.intent\" />\r\n      </div>\r\n    </div>\r\n    <!-- 图片预览模态框 -->\r\n    <div v-if=\"previewSrc\" class=\"modal d-block\" tabindex=\"-1\" style=\"background: rgba(0,0,0,0.7); z-index: 9999;\" @click.self=\"previewSrc = null\">\r\n      <div class=\"modal-dialog modal-dialog-centered modal-fullscreen d-flex align-items-center justify-content-center m-0\">\r\n        <img :src=\"previewSrc\" class=\"img-fluid rounded\" style=\"max-width: 90vw; max-height: 90vh;\" @click=\"previewSrc = null\" />\r\n        <button type=\"button\" class=\"btn-close btn-close-white position-absolute\" style=\"top: 20px; right: 20px;\" @click=\"previewSrc = null\"></button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n    <!-- 已选文件预览区 -->\r\n    <div v-if=\"selectedImages.length > 0 || selectedDocs.length > 0\" class=\"mb-2 d-flex flex-wrap gap-2 align-items-center\">\r\n      <!-- 图片预览 -->\r\n      <div v-for=\"(img, index) in selectedImages\" :key=\"'img-'+index\" class=\"position-relative\">\r\n        <img :src=\"img\" class=\"rounded\" style=\"width: 60px; height: 60px; object-fit: cover; cursor: pointer;\" @click=\"previewImage(img)\" />\r\n        <button type=\"button\" class=\"btn-close position-absolute\" style=\"top: -5px; right: -5px; font-size: 10px; background: #fff; border-radius: 50%; padding: 2px;\" @click=\"removeImage(index)\"></button>\r\n      </div>\r\n      <!-- 文档预览 -->\r\n      <div v-for=\"(doc, index) in selectedDocs\" :key=\"'doc-'+index\" class=\"d-flex align-items-center gap-2 bg-light rounded px-2 py-1\">\r\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" fill=\"currentColor\" class=\"text-secondary\" viewBox=\"0 0 16 16\">\r\n          <path d=\"M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z\"/>\r\n        </svg>\r\n        <span class=\"text-truncate\" style=\"max-width: 100px; font-size: 12px;\">{{ doc.name }}</span>\r\n        <button type=\"button\" class=\"btn-close\" style=\"font-size: 8px;\" @click=\"removeDoc(index)\"></button>\r\n      </div>\r\n    </div>\r\n    <!-- 输入框区域 -->\r\n    <div class=\"input-group\">\r\n      <!-- 回形针上传按钮（带徽标） -->\r\n      <div class=\"position-relative\">\r\n        <button class=\"btn btn-outline-secondary\" type=\"button\" title=\"上传图片或文件\" @click=\"triggerUpload\">\r\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"currentColor\" viewBox=\"0 0 16 16\">\r\n            <path d=\"M4.5 3a2.5 2.5 0 0 1 5 0v9a1.5 1.5 0 0 1-3 0V5a.5.5 0 0 1 1 0v9a3 3 0 0 0 6 0V5a.5.5 0 0 1 1 0v9a4 4 0 0 1-8 0V3z\"/>\r\n            <path d=\"M9.5 1H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h5.5a.5.5 0 0 0 0-1H4a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h5.5a.5.5 0 0 0 0-1H9.5z\"/>\r\n          </svg>\r\n        </button>\r\n        <!-- 已选文件数量徽标 -->\r\n        <span v-if=\"totalSelectedCount > 0\" class=\"position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger\" style=\"font-size: 10px;\">\r\n          {{ totalSelectedCount }}\r\n        </span>\r\n      </div>\r\n      <!-- 隐藏的文件上传input -->\r\n      <input ref=\"uploadInput\" type=\"file\" multiple accept=\"image/*,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.pdf\" style=\"display: none;\" @change=\"handleFileUpload\" />\r\n      <input v-model=\"inputContent\" type=\"text\" class=\"form-control\" placeholder=\"请输入你的问题...\" @keyup.enter=\"sendMsg\">\r\n      <button class=\"btn btn-primary\" type=\"button\" @click=\"sendMsg\">发送</button>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport ResultCard from './ResultCard.vue'\r\nexport default {\r\n  name: 'ChatBox',\r\n  components: { ResultCard },\r\n  data() {\r\n    return {\r\n      inputContent: '',      // 输入内容\r\n      msgList: [],           // 消息列表\r\n      userId: 1,             // 测试用户ID，可扩展为登录后获取\r\n      selectedImages: [],    // 已选图片数组（base64，未发送）\r\n      selectedDocs: [],      // 已选文档数组 {name, base64}\r\n      previewSrc: null,      // 图片预览模态框\r\n      isRecording: false,   // 语音录音状态\r\n      mediaRecorder: null,  // 媒体录制器\r\n      audioChunks: []       // 录音数据块\r\n    }\r\n  },\r\n  computed: {\r\n    // 已选文件总数\r\n    totalSelectedCount() {\r\n      return this.selectedImages.length + this.selectedDocs.length\r\n    }\r\n  },\r\n  mounted() {\r\n    // 存储测试用户ID到Cookies\r\n    this.$cookies.set('userId', this.userId, '7d')\r\n  },\r\n  methods: {\r\n    // 触发上传（统一入口）\r\n    triggerUpload() {\r\n      this.$refs.uploadInput.click()\r\n    },\r\n    // 处理文件上传（图片+文档）\r\n    handleFileUpload(event) {\r\n      const files = event.target.files\r\n      if (!files || files.length === 0) return\r\n      \r\n      let imageCount = this.selectedImages.length\r\n      let docCount = this.selectedDocs.length\r\n      \r\n      for (let i = 0; i < files.length; i++) {\r\n        const file = files[i]\r\n        \r\n        // 最多4张图片\r\n        if (file.type.startsWith('image/') && imageCount < 4) {\r\n          this.convertFileToBase64(file, (base64) => {\r\n            this.selectedImages.push(base64)\r\n          })\r\n          imageCount++\r\n        }\r\n        // 最多2个文档\r\n        else if (!file.type.startsWith('image/') && docCount < 2) {\r\n          this.convertFileToBase64(file, (base64) => {\r\n            this.selectedDocs.push({ name: file.name, base64: base64 })\r\n          })\r\n          docCount++\r\n        }\r\n        // 超出限制时提示\r\n        else if (file.type.startsWith('image/') && imageCount >= 4) {\r\n          this.$message && this.$message.warning('最多只能上传4张图片')\r\n          break\r\n        }\r\n        else if (docCount >= 2) {\r\n          this.$message && this.$message.warning('最多只能上传2个文档')\r\n          break\r\n        }\r\n      }\r\n      \r\n      // 文件大小校验（图片10MB，文档20MB）\r\n      for (let i = 0; i < files.length; i++) {\r\n        const file = files[i]\r\n        if (file.type.startsWith('image/') && file.size > 10 * 1024 * 1024) {\r\n          this.$message && this.$message.warning('图片大小不能超过10MB')\r\n          return\r\n        }\r\n        if (!file.type.startsWith('image/') && file.size > 20 * 1024 * 1024) {\r\n          this.$message && this.$message.warning('文件大小不能超过20MB')\r\n          return\r\n        }\r\n      }\r\n      \r\n      event.target.value = ''\r\n    },\r\n    // 移除已选图片\r\n    removeImage(index) {\r\n      this.selectedImages.splice(index, 1)\r\n    },\r\n    // 移除已选文档\r\n    removeDoc(index) {\r\n      this.selectedDocs.splice(index, 1)\r\n    },\r\n    // 文件转Base64\r\n    convertFileToBase64(file, callback) {\r\n      const reader = new FileReader()\r\n      reader.onload = (e) => callback(e.target.result)\r\n      reader.readAsDataURL(file)\r\n    },\r\n    // 语音输入（录音转文字需要后端ASR，这里仅做录音演示）\r\n    async toggleVoice() {\r\n      if (this.isRecording) {\r\n        // 停止录音\r\n        if (this.mediaRecorder) {\r\n          this.mediaRecorder.stop()\r\n          this.mediaRecorder.onstop = () => {\r\n            const audioBlob = new Blob(this.audioChunks, { type: 'audio/webm' })\r\n            this.audioChunks = []\r\n            alert('语音已录制（ASR语音转文字功能待接入）')\r\n          }\r\n        }\r\n        this.isRecording = false\r\n      } else {\r\n        // 开始录音\r\n        try {\r\n          const stream = await navigator.mediaDevices.getUserMedia({ audio: true })\r\n          this.mediaRecorder = new MediaRecorder(stream)\r\n          this.audioChunks = []\r\n          this.mediaRecorder.ondataavailable = (e) => {\r\n            if (e.data.size > 0) this.audioChunks.push(e.data)\r\n          }\r\n          this.mediaRecorder.start()\r\n          this.isRecording = true\r\n        } catch (err) {\r\n          alert('请允许麦克风权限后使用语音输入')\r\n          console.error(err)\r\n        }\r\n      }\r\n    },\r\n    // 清除对话历史\r\n    clearHistory() {\r\n      if (confirm('确定要清除当前对话历史吗？')) {\r\n        this.msgList = []\r\n        // 调用后端清除历史\r\n        this.$axios.post('/agent/clear-history', null, {\r\n          params: { userId: this.userId }\r\n        }).then(() => {\r\n          this.$message && this.$message.success('对话历史已清除')\r\n        }).catch(() => {\r\n          // 后端未实现清除接口时静默失败\r\n        })\r\n      }\r\n    },\r\n    // 预览大图\r\n    previewImage(src) {\r\n      this.previewSrc = src\r\n    },\r\n    // 轻量markdown渲染（纯文本时原样输出，有markdown符号时转为HTML）\r\n    renderMarkdown(text) {\r\n      if (!text) return ''\r\n      let html = text\r\n        // 转义HTML特殊字符，防止XSS\r\n        .replace(/&/g, '&amp;')\r\n        .replace(/</g, '&lt;')\r\n        .replace(/>/g, '&gt;')\r\n      // 检查是否包含markdown标记\r\n      const hasMd = /[#*`>\\-_~\\[!]/.test(text)\r\n      if (!hasMd) return text  // 纯文本直接返回，不包裹html标签\r\n      // 有markdown → 逐步转换\r\n      html = html\r\n        // 代码块 ```code``` → <pre><code>\r\n        .replace(/```([\\s\\S]*?)```/g, '<pre><code>$1</code></pre>')\r\n        // 行内代码 `code` → <code>\r\n        .replace(/`([^`]+)`/g, '<code>$1</code>')\r\n        // 标题 ### → <h3> (支持h1-h4)\r\n        .replace(/^#### (.+)$/gm, '<h4>$1</h4>')\r\n        .replace(/^### (.+)$/gm, '<h3>$1</h3>')\r\n        .replace(/^## (.+)$/gm, '<h2>$1</h2>')\r\n        .replace(/^# (.+)$/gm, '<h1>$1</h1>')\r\n        // 粗斜体 ***text*** → <strong><em>\r\n        .replace(/\\*\\*\\*(.+?)\\*\\*\\*/g, '<strong><em>$1</em></strong>')\r\n        // 粗体 **text** → <strong>\r\n        .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\r\n        // 斜体 *text* → <em>（排除已处理的粗体）\r\n        .replace(/(?<!\\*)\\*([^*]+)\\*(?!\\*)/g, '<em>$1</em>')\r\n        // 引用 > text → <blockquote>\r\n        .replace(/^&gt; (.+)$/gm, '<blockquote>$1</blockquote>')\r\n        // 无序列表 - item / * item\r\n        .replace(/^[\\-*] (.+)$/gm, '<li>$1</li>')\r\n        // 连续的<li>用<ul>包裹（简单处理）\r\n        .replace(/(<li>.*<\\/li>(\\r?\\n)?)+/g, '<ul>$&</ul>')\r\n        // 段落分隔：两个以上换行\r\n        .replace(/\\n\\n+/g, '</p><p>')\r\n        // 单个换行 → <br>\r\n        .replace(/\\n/g, '<br>')\r\n      return '<p>' + html + '</p>'\r\n    },\r\n    // 发送消息\r\n    async sendMsg() {\r\n      const text = this.inputContent.trim()\r\n      const hasImages = this.selectedImages.length > 0\r\n      const hasDocs = this.selectedDocs.length > 0\r\n      \r\n      if (!text && !hasImages && !hasDocs) {\r\n        this.$message && this.$message.warning('请输入内容或选择图片/文件！')\r\n        return\r\n      }\r\n      \r\n      // 1. 添加用户消息到列表（带图片和文档预览）\r\n      this.msgList.push({\r\n        isUser: true,\r\n        content: text || (hasDocs ? '(文件)' : '(图片)'),\r\n        images: [...this.selectedImages],\r\n        docs: [...this.selectedDocs]\r\n      })\r\n      \r\n      const content = text\r\n      const images = [...this.selectedImages]\r\n      const docs = [...this.selectedDocs]\r\n      \r\n      this.inputContent = ''\r\n      this.selectedImages = []\r\n      this.selectedDocs = []\r\n      \r\n      // 2. 滚动到底部\r\n      this.$nextTick(() => {\r\n        const chatContent = document.getElementById('chatContent')\r\n        chatContent.scrollTop = chatContent.scrollHeight\r\n      })\r\n      \r\n      // 3. 调用后端接口（区分有图/有文档/纯文本）\r\n      try {\r\n        let res\r\n        if (hasImages || hasDocs) {\r\n          // 带图片或文档：使用FormData\r\n          const formData = new FormData()\r\n          formData.append('content', content)\r\n          formData.append('userId', this.userId)\r\n          // 发送第一张图片（多图可以循环发送或合并）\r\n          if (hasImages) {\r\n            formData.append('imageBase64', images[0])\r\n          }\r\n          res = await this.$axios.post('/agent/chat-with-image', formData, {\r\n            headers: { 'Content-Type': 'multipart/form-data' }\r\n          })\r\n        } else {\r\n          // 纯文本：保持原有逻辑\r\n          res = await this.$axios.post('/agent/chat', null, {\r\n            params: {\r\n              content: content,\r\n              userId: this.userId\r\n            }\r\n          })\r\n        }\r\n        if (res.data.code === 200) {\r\n          // 4. 添加机器人消息到列表\r\n          this.msgList.push({\r\n            isUser: false,\r\n            content: res.data.data.reply,\r\n            data: res.data.data.data,\r\n            intent: res.data.data.intent\r\n          })\r\n        } else {\r\n          this.msgList.push({\r\n            isUser: false,\r\n            content: '服务出错了：' + res.data.msg\r\n          })\r\n        }\r\n      } catch (err) {\r\n        console.error(err)\r\n        this.msgList.push({\r\n          isUser: false,\r\n          content: '网络出错了，请重试！'\r\n        })\r\n      } finally {\r\n        // 5. 滚动到底部\r\n        this.$nextTick(() => {\r\n          const chatContent = document.getElementById('chatContent')\r\n          chatContent.scrollTop = chatContent.scrollHeight\r\n        })\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.chat-box {\r\n  background-color: #f8f9fa;\r\n}\r\n.chat-content {\r\n  scroll-behavior: smooth;\r\n}\r\n/* AI消息markdown渲染样式 */\r\n.ai-msg