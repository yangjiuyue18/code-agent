    this.getRemindList()\r\n  },\r\n  methods: {\r\n    // 获取提醒列表\r\n    async getRemindList() {\r\n      try {\r\n        const res = await this.$axios.get('/remind/list', {\r\n          params: { userId: this.userId }\r\n        })\r\n        if (res.data.code === 200) {\r\n          this.remindList = res.data.data\r\n        }\r\n      } catch (err) {\r\n        console.error(err)\r\n        this.$message && this.$message.error('查询提醒失败！')\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n"]}]}